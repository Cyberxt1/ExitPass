[debug] [2026-04-01T11:15:35.152Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/exiteasy-1/rulesets {"name":"projects/exiteasy-1/rulesets/b235256a-f7b9-459f-8ac7-074114fe4e7f","source":{"files":[{"content":"  rules_version = '2';\n\n  service cloud.firestore {\n    match /databases/{database}/documents {\n      function isSignedIn() {\n        return request.auth != null;\n      }\n\n      function isOwner(userId) {\n        return isSignedIn() && request.auth.uid == userId;\n      }\n\n      function currentUserProfile() {\n        return isSignedIn()\n          ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data\n          : null;\n      }\n\n      function role() {\n        return isSignedIn() && request.auth.token.email == 'oluokundavid4@gmail.com'\n          ? 'super_admin'\n          : currentUserProfile() != null && currentUserProfile().role is string\n          ? currentUserProfile().role\n          : (isSignedIn() ? request.auth.token.role : null);\n      }\n\n      function isAdmin() {\n        return role() in ['hall_admin', 'chaplaincy', 'super_admin'];\n      }\n\n      function isSuperAdmin() {\n        return role() == 'super_admin';\n      }\n\n      function isChaplaincy() {\n        return role() == 'chaplaincy';\n      }\n\n      function isHallAdmin() {\n        return role() == 'hall_admin';\n      }\n\n      function isSecurity() {\n        return role() == 'security';\n      }\n\n      function isPrivileged() {\n        return isAdmin() || isSecurity();\n      }\n\n      function currentUserHostel() {\n        return currentUserProfile() != null && currentUserProfile().hostel is string\n          ? currentUserProfile().hostel\n          : null;\n      }\n\n      function hostelDoc(hostelKey) {\n        return hostelKey is string\n          && exists(/databases/$(database)/documents/hostels/$(hostelKey))\n          ? get(/databases/$(database)/documents/hostels/$(hostelKey)).data\n          : null;\n      }\n\n      function currentUserHostelDoc() {\n        return currentUserHostel() is string\n          ? hostelDoc(currentUserHostel())\n          : null;\n      }\n\n      function hostelsMatch(hostelValue) {\n        return currentUserHostel() is string\n          && hostelValue is string\n          && (\n            hostelValue == currentUserHostel()\n            || (\n              currentUserHostelDoc() != null\n              && (\n                currentUserHostelDoc().name == hostelValue\n                || currentUserHostelDoc().slug == hostelValue\n              )\n            )\n            || (\n              hostelDoc(hostelValue) != null\n              && (\n                hostelDoc(hostelValue).name == currentUserHostel()\n                || hostelDoc(hostelValue).slug == currentUserHostel()\n              )\n            )\n          );\n      }\n\n      function isLeadStaffEmail() {\n        return request.resource.data.email in [\n          'oluokundavid4@gmail.com',\n          'xplick@gmail.com',\n          'blyinkr4@gmail.com'\n        ];\n      }\n\n      function isApprovedLeadStaffCreate() {\n        return request.resource.data.role in ['super_admin', 'security', 'chaplaincy']\n          && (\n            (request.resource.data.role == 'super_admin'\n              && request.resource.data.email == 'oluokundavid4@gmail.com')\n            ||\n            (request.resource.data.role == 'security'\n              && request.resource.data.email == 'xplick@gmail.com')\n            ||\n            (request.resource.data.role == 'chaplaincy'\n              && request.resource.data.email == 'blyinkr4@gmail.com')\n          );\n      }\n\n      function inviteDoc() {\n        return request.resource.data.inviteToken is string\n          ? get(/databases/$(database)/documents/staffInvites/$(request.resource.data.inviteToken))\n          : null;\n      }\n\n      function hasValidInviteForStaffCreate() {\n        return request.resource.data.inviteToken is string\n          && inviteDoc() != null\n          && inviteDoc().data.status == 'pending'\n          && inviteDoc().data.email == request.resource.data.email\n          && inviteDoc().data.role == request.resource.data.role\n          && (\n            request.resource.data.role != 'hall_admin'\n            || (\n              inviteDoc().data.hostel is string\n              && request.resource.data.hostel == inviteDoc().data.hostel\n            )\n          );\n      }\n\n      function isDirectApprovedStaffCreate() {\n        return request.resource.data.role in ['hall_admin', 'chaplaincy', 'security']\n          && request.resource.data.approvalStatus == 'approved'\n          && request.resource.data.disabled == false;\n      }\n\n      function canCreateStaffProfile(userId) {\n        return isOwner(userId)\n          && request.resource.data.role in ['hall_admin', 'chaplaincy', 'security', 'super_admin']\n          && request.resource.data.email is string\n          && request.resource.data.name is string\n          && request.resource.data.matric is string\n          && (\n            isApprovedLeadStaffCreate()\n            || hasValidInviteForStaffCreate()\n            || isDirectApprovedStaffCreate()\n          );\n      }\n\n      function canCreateStudentProfile(userId) {\n        return isOwner(userId)\n          && request.resource.data.role == 'student'\n          && request.resource.data.email is string\n          && request.resource.data.name is string\n          && request.resource.data.matric is string\n          && request.resource.data.matric.matches('^[0-9]{2}/[0-9]{4}$')\n          && !isLeadStaffEmail();\n      }\n\n      function canCreateManagedStudentProfile() {\n        return isSignedIn()\n          && isSuperAdmin()\n          && request.resource.data.role == 'student'\n          && request.resource.data.email is string\n          && request.resource.data.name is string\n          && request.resource.data.matric is string\n          && request.resource.data.matric.matches('^[0-9]{2}/[0-9]{4}$')\n          && request.resource.data.matricNormalized.matches('^[0-9]{2}/[0-9]{4}$')\n          && request.resource.data.disabled == false;\n      }\n\n      function canCreateManagedStaffProfile() {\n        return isSignedIn()\n          && isSuperAdmin()\n          && request.resource.data.role in ['hall_admin', 'chaplaincy', 'security']\n          && request.resource.data.email is string\n          && request.resource.data.name is string\n          && request.resource.data.matric is string\n          && request.resource.data.approvalStatus == 'approved'\n          && request.resource.data.disabled == false;\n      }\n\n      function canWriteStudentAccessDirectory(directoryId) {\n        return request.resource.data.userId is string\n          && request.resource.data.directoryId == directoryId\n          && directoryId.matches('^[0-9]{6}$')\n          && request.resource.data.role == 'student'\n          && request.resource.data.matric is string\n          && request.resource.data.matric.matches('^[0-9]{2}/[0-9]{4}$')\n          && request.resource.data.matricNormalized.matches('^[0-9]{2}/[0-9]{4}$')\n          && request.resource.data.name is string\n          && request.resource.data.email is string\n          && request.resource.data.department is string\n          && request.resource.data.faculty is string\n          && request.resource.data.level is string\n          && request.resource.data.hostel is string\n          && request.resource.data.room is string\n          && (\n            isPrivileged()\n            || (isSignedIn() && request.resource.data.userId == request.auth.uid)\n          );\n      }\n\n      function canWriteStaffInviteDirectory(emailId) {\n        return isSignedIn()\n          && isPrivileged()\n          && request.resource.data.email == emailId\n          && request.resource.data.role is string\n          && request.resource.data.status is string;\n      }\n\n      function immutablePassRequestFieldsUnchanged() {\n        return request.resource.data.studentId == resource.data.studentId\n          && request.resource.data.studentSnapshot == resource.data.studentSnapshot\n          && request.resource.data.type == resource.data.type\n          && request.resource.data.destination == resource.data.destination\n          && request.resource.data.reason == resource.data.reason\n          && request.resource.data.departureDate == resource.data.departureDate\n          && request.resource.data.expectedReturnDate == resource.data.expectedReturnDate\n          && request.resource.data.createdBy == resource.data.createdBy\n          && request.resource.data.createdAt == resource.data.createdAt;\n      }\n\n      function canCreateStudentPassRequest() {\n        return isSignedIn()\n          && request.resource.data.studentId == request.auth.uid\n          && request.resource.data.studentSnapshot.role == 'student'\n          && request.resource.data.type in ['short', 'long', 'holiday']\n          && request.resource.data.destination is string\n          && request.resource.data.reason is string\n          && request.resource.data.departureDate is timestamp\n          && request.resource.data.expectedReturnDate is timestamp\n          && request.resource.data.status == 'chaplaincy_required'\n          && request.resource.data.currentStage == 'chaplaincy'\n          && request.resource.data.createdBy == request.auth.uid;\n      }\n\n      function canReviewAtChaplaincyStage() {\n        return immutablePassRequestFieldsUnchanged()\n          && resource.data.status == 'chaplaincy_required'\n          && resource.data.currentStage == 'chaplaincy'\n          && isChaplaincy()\n          && request.resource.data.status in ['pending', 'rejected']\n          && (\n            (request.resource.data.status == 'pending'\n              && request.resource.data.currentStage == 'hall_admin'\n              && request.resource.data.chaplainApproval.status == 'approved')\n            ||\n            (request.resource.data.status == 'rejected'\n              && request.resource.data.currentStage == 'completed'\n              && request.resource.data.chaplainApproval.status == 'rejected'\n              && request.resource.data.rejectionReason is string)\n          );\n      }\n\n      function canReviewAtHallStage() {\n        return immutablePassRequestFieldsUnchanged()\n          && resource.data.status == 'pending'\n          && resource.data.currentStage == 'hall_admin'\n          && request.resource.data.chaplainApproval == resource.data.chaplainApproval\n          && (\n            isHallAdmin()\n            && hostelsMatch(resource.data.studentSnapshot.hostel)\n          )\n          && request.resource.data.status in ['approved', 'rejected']\n          && (\n            (request.resource.data.status == 'approved'\n              && request.resource.data.currentStage == 'completed'\n              && request.resource.data.hallAdminApproval.status == 'approved'\n              && request.resource.data.approvedAt is timestamp)\n            ||\n            (request.resource.data.status == 'rejected'\n              && request.resource.data.currentStage == 'completed'\n              && request.resource.data.hallAdminApproval.status == 'rejected'\n              && request.resource.data.rejectionReason is string)\n          );\n      }\n\n      match /users/{userId} {\n        allow read: if isOwner(userId) || isPrivileged();\n        allow create: if canCreateStudentProfile(userId)\n          || canCreateStaffProfile(userId)\n          || canCreateManagedStudentProfile()\n          || canCreateManagedStaffProfile();\n        allow update: if (\n            isOwner(userId)\n            && resource.data.role == 'student'\n            && request.resource.data.role == resource.data.role\n            && request.resource.data.email == resource.data.email\n            && request.resource.data.permissions == resource.data.permissions\n            && request.resource.data.disabled == resource.data.disabled\n            && request.resource.data.approvalStatus == resource.data.approvalStatus\n            && request.resource.data.approvalReviewedBy == resource.data.approvalReviewedBy\n            && request.resource.data.approvalReviewedAt == resource.data.approvalReviewedAt\n            && request.resource.data.rejectionReason == resource.data.rejectionReason\n          ) || (\n            isSignedIn()\n            && isSuperAdmin()\n            && resource.data.role in ['student', 'hall_admin', 'chaplaincy', 'security']\n            && request.resource.data.role == resource.data.role\n            && request.resource.data.email == resource.data.email\n            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([\n              'disabled',\n              'updatedAt',\n              'approvalStatus',\n              'approvalReviewedBy',\n              'approvalReviewedAt',\n              'rejectionReason'\n            ])\n          );\n        allow delete: if false;\n      }\n\n      match /studentAccessDirectory/{directoryId} {\n        allow read: if true;\n        allow create, update: if canWriteStudentAccessDirectory(directoryId);\n        allow delete: if isSignedIn() && isPrivileged();\n      }\n\n      match /staffInviteDirectory/{emailId} {\n        allow read: if true;\n        allow create, update: if canWriteStaffInviteDirectory(emailId);\n        allow delete: if isSignedIn() && isPrivileged();\n      }\n\n      match /passRequests/{requestId} {\n        allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());\n        allow create: if canCreateStudentPassRequest();\n        allow update: if canReviewAtChaplaincyStage() || canReviewAtHallStage();\n        allow delete: if false;\n      }\n\n      match /hostels/{hostelId} {\n        allow read: if true;\n        allow create: if isSignedIn()\n          && isSuperAdmin()\n          && request.resource.data.name is string\n          && request.resource.data.slug == hostelId\n          && request.resource.data.createdBy == request.auth.uid;\n        allow update: if isSignedIn()\n          && (\n            isSuperAdmin()\n            || (\n              isHallAdmin()\n              && (\n                hostelsMatch(resource.data.name)\n                || hostelsMatch(hostelId)\n              )\n              && request.resource.data.hallAdminEmail == currentUserProfile().email\n            )\n          );\n        allow delete: if false;\n      }\n\n      match /staffInvites/{inviteId} {\n        allow get: if resource.data.status == 'pending' || (isSignedIn() && isPrivileged());\n        allow list: if isSignedIn() && isPrivileged();\n        allow create: if isSignedIn()\n          && (\n            (isSuperAdmin() && request.resource.data.role in ['hall_admin', 'chaplaincy', 'security'])\n            || (isChaplaincy() && request.resource.data.role == 'chaplaincy')\n            || (isSecurity() && request.resource.data.role == 'security')\n          )\n          && request.resource.data.email is string\n          && request.resource.data.status == 'pending'\n          && request.resource.data.createdBy == request.auth.uid;\n        allow update: if isSignedIn()\n          && resource.data.status == 'pending'\n          && request.resource.data.status == 'claimed'\n          && request.resource.data.email == resource.data.email\n          && request.resource.data.role == resource.data.role\n          && request.resource.data.createdBy == resource.data.createdBy\n          && request.resource.data.claimedBy == request.auth.uid\n          && currentUserProfile() != null\n          && currentUserProfile().email == resource.data.email;\n        allow delete: if false;\n      }\n\n      match /passes/{passId} {\n        allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isPrivileged());\n        allow create: if isSignedIn()\n          && request.resource.data.requestId == passId\n          && request.resource.data.studentId is string\n          && request.resource.data.status == 'approved'\n          && request.resource.data.currentStage == 'completed'\n          && (\n            isSuperAdmin()\n            ||\n            (isHallAdmin()\n              && hostelsMatch(request.resource.data.studentSnapshot.hostel))\n          );\n        allow update: if isSignedIn()\n          && isSecurity()\n          && resource.data.status == 'approved'\n          && request.resource.data.studentId == resource.data.studentId\n          && request.resource.data.requestId == resource.data.requestId\n          && request.resource.data.qrCode == resource.data.qrCode\n          && request.resource.data.studentSnapshot == resource.data.studentSnapshot\n          && request.resource.data.departureDate == resource.data.departureDate\n          && request.resource.data.expectedReturnDate == resource.data.expectedReturnDate\n          && request.resource.data.type == resource.data.type\n          && request.resource.data.destination == resource.data.destination\n          && request.resource.data.reason == resource.data.reason\n          && request.resource.data.chaplainApproval == resource.data.chaplainApproval\n          && request.resource.data.hallAdminApproval == resource.data.hallAdminApproval\n          && request.resource.data.status == 'completed'\n          && request.resource.data.actualReturnDate is timestamp;\n        allow delete: if false;\n      }\n\n      match /holidays/{holidayId} {\n        allow read: if isSignedIn();\n        allow create: if isSignedIn()\n          && isSuperAdmin()\n          && request.resource.data.title is string\n          && request.resource.data.description is string\n          && request.resource.data.departureDate is timestamp\n          && request.resource.data.expectedReturnDate is timestamp\n          && request.resource.data.createdBy == request.auth.uid;\n        allow update, delete: if false;\n      }\n\n      match /announcements/{announcementId} {\n        allow read: if isSignedIn();\n        allow create: if isSignedIn()\n          && isAdmin()\n          && request.resource.data.title is string\n          && request.resource.data.message is string\n          && request.resource.data.createdBy == request.auth.uid;\n        allow update, delete: if false;\n      }\n\n      match /notifications/{notificationId} {\n        allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isPrivileged());\n        allow create: if isSignedIn()\n          && isPrivileged()\n          && request.resource.data.userId is string\n          && request.resource.data.title is string\n          && request.resource.data.message is string;\n        allow update, delete: if false;\n      }\n\n      match /scans/{scanId} {\n        allow read: if isSignedIn() && isPrivileged();\n        allow create: if isSignedIn()\n          && isPrivileged()\n          && request.resource.data.qrCode is string\n          && request.resource.data.location is string\n          && request.resource.data.eventType in ['scan', 'return']\n          && request.resource.data.status in ['success', 'failed'];\n        allow update, delete: if false;\n      }\n\n      match /{document=**} {\n        allow read, write: if false;\n      }\n    }\n  }\n","name":"firestore.rules"}]},"createTime":"2026-04-01T11:15:42.858847Z","metadata":{"services":["cloud.firestore"]}}
